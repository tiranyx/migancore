# ============================================
# MIGANCORE — Environment Configuration
# ============================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.

# --- Database ---
PG_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://ado_app:${PG_PASSWORD}@postgres:5432/ado

# --- Redis ---
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- Qdrant ---
QDRANT_API_KEY=change_me_in_production
QDRANT_URL=http://qdrant:6333

# --- Letta ---
LETTA_PASSWORD=change_me_in_production
LETTA_URL=http://letta:8283

# --- Ollama ---
OLLAMA_URL=http://ollama:11434

# --- JWT ---
# Generate with:
# openssl genrsa -out /etc/ado/keys/private.pem 2048
# openssl rsa -in /etc/ado/keys/private.pem -pubout -out /etc/ado/keys/public.pem
JWT_PRIVATE_KEY_PATH=/etc/ado/keys/private.pem
JWT_PUBLIC_KEY_PATH=/etc/ado/keys/public.pem

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- RunPod (Training) ---
RUNPOD_API_KEY=your_runpod_api_key

# --- External APIs ---
# Tavily or SerpAPI for web search
TAVILY_API_KEY=your_tavily_key
SERPER_API_KEY=your_serper_key

# --- Langfuse (Observability) ---
LANGFUSE_SECRET=change_me
LANGFUSE_SALT=change_me

# --- Security ---
SECRET_KEY=generate_a_random_32byte_string
