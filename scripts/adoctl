#!/bin/bash
# ============================================================
# adoctl — MiganCore Operational Controller
# The ONLY blessed interface for agents working on MiganCore.
# Prevents accidental modification of forbidden zones.
# ============================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="/opt/ado"
COMPOSE_FILE="${PROJECT_ROOT}/docker-compose.yml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${GREEN}[✓]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
info() { echo -e "${BLUE}[ℹ]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; exit 1; }

# --- Preflight Safety Checks ---
preflight() {
    # Must be in /opt/ado
    if [ "$(pwd)" != "$PROJECT_ROOT" ]; then
        error "adoctl must run from ${PROJECT_ROOT}. Current: $(pwd)"
    fi

    # Docker compose config must pass
    if ! docker compose config >/dev/null 2>&1; then
        error "docker-compose.yml is invalid. Run 'docker compose config' to diagnose."
    fi

    # Caddy must not bind 80/443 in current compose config
    if docker compose config | grep -q '"80:80"' || docker compose config | grep -q '"443:443"'; then
        if docker compose config | grep -A2 'caddy:' | grep -q 'profiles'; then
            : # Caddy has profile, safe
        else
            error "Caddy is configured to bind 80/443. This conflicts with nginx aaPanel. Disable Caddy or add 'ingress' profile."
        fi
    fi
}

# --- Help ---
show_help() {
    cat << 'EOF'
adoctl — MiganCore Operational Controller

USAGE:
    adoctl <command> [args]

COMMANDS:
    ps                  Show running MiganCore containers
    logs <service>      Show logs for a service
    deploy <service>    Build and restart a service
    health              Check MiganCore health endpoints
    model-status        Show Ollama models and RAM usage
    nginx-test          Test nginx configuration
    preflight           Run safety checks only
    backup              Backup data directories
    forbidden-check     Verify no forbidden paths were touched

EXAMPLES:
    adoctl ps
    adoctl logs api
    adoctl deploy api
    adoctl health
    adoctl model-status

SAFETY:
    adoctl will REFUSE to run if:
    - You are not in /opt/ado
    - docker-compose.yml binds 80/443 without profile protection
    - Any forbidden path appears in git diff
EOF
}

# --- Commands ---
cmd_ps() {
    cd "$PROJECT_ROOT"
    docker compose ps
}

cmd_logs() {
    local service="${1:-}"
    if [ -z "$service" ]; then
        error "Usage: adoctl logs <service>"
    fi
    cd "$PROJECT_ROOT"
    docker compose logs --tail=100 -f "$service"
}

cmd_deploy() {
    local service="${1:-}"
    if [ -z "$service" ]; then
        error "Usage: adoctl deploy <service>"
    fi
    cd "$PROJECT_ROOT"
    preflight
    info "Deploying $service..."
    docker compose up -d --build "$service"
    log "$service deployed"
}

cmd_health() {
    info "Checking MiganCore health..."

    # Check API
    if curl -fsS http://127.0.0.1:18000/health >/dev/null 2>&1; then
        log "API /health → OK"
    else
        warn "API /health → FAIL (is API running?)"
    fi

    # Check Ollama
    if docker compose exec -T ollama ollama list >/dev/null 2>&1; then
        log "Ollama → OK"
    else
        warn "Ollama → FAIL"
    fi

    # Check Postgres
    if docker compose exec -T postgres pg_isready -U ado >/dev/null 2>&1; then
        log "Postgres → OK"
    else
        warn "Postgres → FAIL"
    fi

    # Check Qdrant
    if curl -fsS http://localhost:6333/healthz >/dev/null 2>&1; then
        log "Qdrant → OK"
    else
        warn "Qdrant → FAIL (or not exposed to host)"
    fi
}

cmd_model_status() {
    info "Ollama models:"
    docker compose exec -T ollama ollama list 2>/dev/null || warn "Ollama not responding"

    info ""
    info "Container RAM usage:"
    docker stats --no-stream --format "table {{.Name}}\t{{.MemUsage}}\t{{.MemPerc}}" 2>/dev/null || true

    info ""
    info "Host RAM:"
    free -h
}

cmd_nginx_test() {
    info "Testing nginx configuration..."
    nginx -t
}

cmd_preflight() {
    cd "$PROJECT_ROOT"
    preflight
    log "All preflight checks passed. Safe to proceed."
}

cmd_backup() {
    local backup_dir="/opt/ado/backups/$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$backup_dir"
    info "Backing up data to $backup_dir..."

    # Backup postgres data
    if [ -d /opt/ado/data/postgres ]; then
        tar czf "$backup_dir/postgres.tar.gz" -C /opt/ado/data postgres
    fi

    # Backup ollama models
    if [ -d /opt/ado/data/ollama ]; then
        tar czf "$backup_dir/ollama.tar.gz" -C /opt/ado/data ollama
    fi

    # Backup .env
    if [ -f /opt/ado/.env ]; then
        cp /opt/ado/.env "$backup_dir/.env"
    fi

    log "Backup complete: $backup_dir"
}

cmd_forbidden_check() {
    info "Checking for forbidden path modifications..."

    local forbidden=(
        "/opt/sidix"
        "/root/sidix"
        "/var/www/ixonomic"
        "/www/server/panel"
    )

    local found=0
    for path in "${forbidden[@]}"; do
        if [ -n "$(git diff --name-only 2>/dev/null | grep "$path" || true)" ]; then
            error "FORBIDDEN: git diff touches $path"
            found=1
        fi
    done

    if [ $found -eq 0 ]; then
        log "No forbidden paths touched. Safe."
    fi
}

# --- Main ---
case "${1:-}" in
    ps) cmd_ps ;;
    logs) cmd_logs "${2:-}" ;;
    deploy) cmd_deploy "${2:-}" ;;
    health) cmd_health ;;
    model-status) cmd_model_status ;;
    nginx-test) cmd_nginx_test ;;
    preflight) cmd_preflight ;;
    backup) cmd_backup ;;
    forbidden-check) cmd_forbidden_check ;;
    help|--help|-h) show_help ;;
    *)
        echo "Unknown command: ${1:-}"
        show_help
        exit 1
        ;;
esac
