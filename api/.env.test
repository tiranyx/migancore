# ============================================================
# MIGANCORE — Test Environment Configuration
# Copy to api/.env.test and load with: export $(cat .env.test | xargs)
# ============================================================

ENVIRONMENT=testing

# Database (matches docker-compose.test.yml)
DATABASE_URL=postgresql+asyncpg://ado_app:test@localhost:5432/ado_test

# Redis
REDIS_URL=redis://:test@localhost:6379/0

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# LLM (mocked in tests)
OLLAMA_URL=http://localhost:11434
LETTA_URL=http://localhost:8283
DEFAULT_MODEL=migancore:0.4

# JWT — generate test keys with:
#   mkdir -p /tmp/test_keys
#   openssl genrsa -out /tmp/test_keys/private.pem 2048
#   openssl rsa -in /tmp/test_keys/private.pem -pubout -out /tmp/test_keys/public.pem
JWT_PRIVATE_KEY_PATH=/tmp/test_keys/private.pem
JWT_PUBLIC_KEY_PATH=/tmp/test_keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin & License (test-only, not secret)
ADMIN_SECRET_KEY=test-admin-key-for-ci-only-32chars
LICENSE_SECRET_KEY=test-license-secret-for-ci-only-32chars
LICENSE_DEMO_MODE=true

# Display
ADO_DISPLAY_NAME=TestMigan

# External APIs (disabled during tests)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
FAL_KEY=
ELEVENLABS_KEY=
