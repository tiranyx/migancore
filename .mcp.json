{
  "inputs": [
    {
      "id": "hostinger_api_token",
      "type": "promptString",
      "description": "Hostinger API Token"
    }
  ],
  "servers": {
    "hostinger-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["hostinger-api-mcp@latest"],
      "env": {
        "API_TOKEN": "${input:hostinger_api_token}"
      }
    }
  }
}
